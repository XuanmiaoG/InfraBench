# Cloudflare Pages / compatible hosts. GitHub Pages ignores this file;
# if infraben.ch is proxied through Cloudflare, mirror these as Cache Rules.
/
  Cache-Control: public, max-age=300, must-revalidate

/next/static/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=604800

/og.jpg
  Cache-Control: public, max-age=604800

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/llms.txt
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600
